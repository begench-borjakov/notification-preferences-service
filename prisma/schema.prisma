generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  marketing
  transactional
  security
}

enum Channel {
  email
  sms
  push
  messenger
}

enum Region {
  GLOBAL
  EU
  US
  TR
}

enum PolicyAction {
  allow
  deny
}

model DefaultPreference {
  id               String           @id @default(uuid())
  notificationType NotificationType @map("notification_type")
  channel          Channel
  enabled          Boolean
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([notificationType, channel])
  @@map("default_preferences")
}

model UserPreference {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  notificationType NotificationType @map("notification_type")
  channel          Channel
  enabled          Boolean
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([userId, notificationType, channel])
  @@map("user_preferences")
}

model UserSettings {
  id                           String   @id @default(uuid())
  userId                       String   @unique @map("user_id")
  optionalNotificationsEnabled Boolean  @default(true) @map("optional_notifications_enabled")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model QuietHours {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  enabled   Boolean
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  timezone  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("quiet_hours")
}

model GlobalPolicy {
  id               String           @id @default(uuid())
  notificationType NotificationType @map("notification_type")
  channel          Channel
  region           Region
  action           PolicyAction
  reason           String?
  enabled          Boolean
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([notificationType, channel, region])
  @@map("global_policies")
}
